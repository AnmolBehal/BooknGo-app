# ─── Environment Template ───
# Copy this file to .env and fill in your real credentials.
# NEVER commit the .env file to version control!

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# RapidAPI
VITE_RAPIDAPI_KEY=

# EmailJS
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Twilio Sandbox (serverless function endpoint you deploy)
# VITE_TWILIO_WEBHOOK_URL=

# Admin email for admin panel access
VITE_ADMIN_EMAIL=admin@bookngo.com

# Stripe Payment Gateway
# Get your keys from https://dashboard.stripe.com/apikeys
# PUBLISHABLE KEY (frontend - safe to expose in browser)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# SECRET KEY (backend server only - NEVER expose to frontend)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
